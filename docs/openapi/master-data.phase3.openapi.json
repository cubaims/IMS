{
  "openapi": "3.0.3",
  "info": {
    "title": "IMS Master Data API",
    "version": "phase-3",
    "description": "Phase 3 master data routes for IMS."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "MasterData"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "responses": {
      "Success": {
        "description": "OK"
      },
      "Unauthorized": {
        "description": "Unauthorized"
      },
      "Forbidden": {
        "description": "Forbidden"
      }
    },
    "schemas": {
      "StorageBinReadModel": {
        "type": "object",
        "required": ["bin_code", "zone", "bin_type", "capacity", "current_occupied", "available_capacity"],
        "properties": {
          "bin_code": {"type": "string", "maxLength": 20},
          "zone": {"type": "string", "maxLength": 10},
          "bin_type": {"type": "string", "maxLength": 20},
          "capacity": {"type": "integer", "minimum": 1},
          "current_occupied": {"type": "integer", "minimum": 0},
          "available_capacity": {"type": "integer", "minimum": 0},
          "status": {"type": "string", "enum": ["正常", "占用", "维护中", "冻结"], "nullable": true},
          "notes": {"type": "string", "nullable": true},
          "created_at": {"type": "string", "format": "date-time", "nullable": true},
          "updated_at": {"type": "string", "format": "date-time", "nullable": true}
        }
      },
      "CreateStorageBinCommand": {
        "type": "object",
        "required": ["bin_code", "zone", "bin_type", "capacity"],
        "properties": {
          "bin_code": {"type": "string", "minLength": 1, "maxLength": 20},
          "zone": {"type": "string", "minLength": 1, "maxLength": 10},
          "bin_type": {"type": "string", "minLength": 1, "maxLength": 20},
          "capacity": {"type": "integer", "minimum": 1},
          "notes": {"type": "string", "nullable": true}
        }
      },
      "UpdateStorageBinCommand": {
        "type": "object",
        "properties": {
          "zone": {"type": "string", "minLength": 1, "maxLength": 10},
          "bin_type": {"type": "string", "minLength": 1, "maxLength": 20},
          "capacity": {"type": "integer", "minimum": 1},
          "status": {"type": "string", "enum": ["正常", "占用", "维护中", "冻结"]},
          "notes": {"type": "string", "nullable": true}
        }
      },
      "BinCapacityUtilizationReadModel": {
        "type": "object",
        "required": ["bin_code", "zone", "capacity", "current_occupied", "available_capacity", "utilization_pct", "capacity_status"],
        "properties": {
          "bin_code": {"type": "string"},
          "zone": {"type": "string"},
          "capacity": {"type": "integer", "minimum": 1},
          "current_occupied": {"type": "integer", "minimum": 0},
          "available_capacity": {"type": "integer", "minimum": 0},
          "utilization_pct": {"type": "string", "example": "42.50"},
          "capacity_status": {"type": "string", "enum": ["空闲", "正常", "接近满仓", "超容量"]}
        }
      },
      "StorageBinPage": {
        "type": "object",
        "properties": {
          "items": {"type": "array", "items": {"$ref": "#/components/schemas/StorageBinReadModel"}},
          "total": {"type": "integer", "minimum": 0},
          "page": {"type": "integer", "minimum": 1},
          "page_size": {"type": "integer", "minimum": 1}
        }
      },
      "ApiResponseStorageBin": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "data": {"$ref": "#/components/schemas/StorageBinReadModel"},
          "message": {"type": "string", "nullable": true}
        }
      },
      "ApiResponseStorageBinPage": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "data": {"$ref": "#/components/schemas/StorageBinPage"},
          "message": {"type": "string", "nullable": true}
        }
      },
      "ApiResponseBinCapacityUtilization": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "data": {"$ref": "#/components/schemas/BinCapacityUtilizationReadModel"},
          "message": {"type": "string", "nullable": true}
        }
      }
    }
  },
  "paths": {
    "/api/master-data/materials": {
      "get": {
        "tags": ["MasterData"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "keyword", "in": "query", "schema": {"type": "string"}},
          {"name": "material_type", "in": "query", "schema": {"type": "string", "enum": ["原材料", "半成品", "成品", "RAW", "SEMI", "FINISHED"]}},
          {"name": "status", "in": "query", "schema": {"type": "string", "enum": ["正常", "停用", "冻结"]}},
          {"name": "sort_by", "in": "query", "schema": {"type": "string", "enum": ["material_id", "material_name", "material_type", "status", "current_stock", "created_at", "updated_at"]}},
          {"name": "sort_order", "in": "query", "schema": {"type": "string", "enum": ["asc", "desc"]}},
          {"name": "page", "in": "query", "schema": {"type": "integer", "minimum": 1}},
          {"name": "page_size", "in": "query", "schema": {"type": "integer", "minimum": 1, "maximum": 200}}
        ],
        "responses": {
          "200": {"$ref": "#/components/responses/Success"},
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "403": {"$ref": "#/components/responses/Forbidden"}
        }
      },
      "post": {
        "tags": ["MasterData"],
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["material_id", "material_name", "material_type", "base_unit", "default_zone", "safety_stock", "reorder_point", "standard_price", "map_price"],
                "properties": {
                  "material_id": {"type": "string", "maxLength": 20},
                  "material_name": {"type": "string", "maxLength": 100},
                  "material_type": {"type": "string", "enum": ["原材料", "半成品", "成品", "RAW", "SEMI", "FINISHED"]},
                  "base_unit": {"type": "string", "maxLength": 10},
                  "default_zone": {"type": "string", "maxLength": 10},
                  "safety_stock": {"type": "integer", "minimum": 0},
                  "reorder_point": {"type": "integer", "minimum": 0},
                  "standard_price": {"type": "number", "minimum": 0},
                  "map_price": {"type": "number", "minimum": 0},
                  "quality_status": {"type": "string", "default": "合格", "enum": ["待检", "合格", "冻结", "报废", "放行", "PENDING", "QUALIFIED", "FROZEN", "SCRAPPED", "RELEASED"]}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"$ref": "#/components/responses/Success"},
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "403": {"$ref": "#/components/responses/Forbidden"}
        }
      }
    },
