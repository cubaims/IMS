          {"name": "is_active", "in": "query", "description": "true returns bins usable for receiving stock: 正常/占用; false returns 维护中/冻结.", "schema": {"type": "boolean"}},
          {"name": "page", "in": "query", "schema": {"type": "integer", "minimum": 1}},
          {"name": "page_size", "in": "query", "schema": {"type": "integer", "minimum": 1, "maximum": 200}}
