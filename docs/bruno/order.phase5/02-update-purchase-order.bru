meta {
  name: 02 Update Purchase Order
  type: http
  seq: 2
}

patch {
  url: {{base_url}}/api/purchase-orders/{{po_id}}
  body: json
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "remark": "phase 5 Bruno purchase order updated",
    "lines": [
      {
        "line_no": 10,
        "material_id": "{{material_id}}",
        "ordered_qty": 100,
        "unit_price": "12.50",
        "expected_bin": "{{bin_code}}"
      }
    ]
  }
}
