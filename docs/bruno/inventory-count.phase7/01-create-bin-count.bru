meta {
  name: 01 Create BIN Count
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/inventory/counts
  body: json
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "count_type": "CYCLE",
    "count_scope": "BIN",
    "bin_code": "{{count_bin}}",
    "remark": "phase 7 Bruno count"
  }
}
